{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"formatter": {
		"indentWidth": 2
	},
	"linter": {
		"rules": {
			"complexity": {
				"noStaticOnlyClass": "off",
				"noThisInStatic": "off"
			}
		},
		"includes": ["**", "!diff.js"]
	},
	"files": {
		"includes": ["**", "!packs/**", "!fvtt/**", "!challenge.css", "!threat.css"]
	}
}
