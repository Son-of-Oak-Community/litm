{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"formatter": {
		"indentWidth": 2
	},
	"linter": {
		"rules": {
			"complexity": {
				"noStaticOnlyClass": "off",
				"noThisInStatic": "off"
			}
		},
		"includes": ["**", "!**/check-keys.js", "!**/diff.js"]
	},
	"files": {
		"includes": ["**", "!foundry", "!**/*.html"]
	}
}
